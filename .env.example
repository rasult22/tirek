# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://tirek_user:tirek_password@localhost:5434/tirek_db

# Option B — individual vars (used when DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5433
# DB_USER=tirek_user
# DB_PASSWORD=tirek_password
# DB_NAME=tirek_db

# ─── Auth ─────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-char-string-minimum
JWT_EXPIRES_IN=7d

# ─── AI ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── Ports ────────────────────────────────────────────────────────
PORT=4111
API_PORT=3000

# ─── Frontend API URL (used by Vite apps) ────────────────────────
# VITE_API_URL=http://localhost:3001
