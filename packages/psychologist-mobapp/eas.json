{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://tirek-production.up.railway.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://tirek-production.up.railway.app"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://tirek-production.up.railway.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "bundleIdentifier": "kz.tirek.psychologist"
      },
      "android": {
        "track": "internal"
      }
    }
  }
}
